# =============================================================================
# Hermes Agent — конфиг для LM Studio на Windows
# Скопируй в .env и заполни
# =============================================================================

# LM Studio API key (из LM Studio → Developer → API Key)
OPENAI_API_KEY=sk-lm-xxxxxxxxxxxxxxxx

# =============================================================================
# TELEGRAM
# =============================================================================
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Твой Telegram user ID (узнать через @userinfobot)
TELEGRAM_ALLOWED_USERS=5120385261

# Канал для cron-уведомлений (твой личный чат с ботом — узнать после первого /start)
# TELEGRAM_HOME_CHANNEL=

# =============================================================================
# ОПЦИОНАЛЬНО
# =============================================================================
TERMINAL_TIMEOUT=120
WEB_TOOLS_DEBUG=false
